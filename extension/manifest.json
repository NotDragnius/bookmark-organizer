{
  "manifest_version": 3,
  "name": "Sifted - Background Capture",
  "version": "1.0",
  "description": "Automatically capture bookmarks added to 'To Sort' and send them to your Sifted repository.",
  "permissions": [
    "bookmarks",
    "storage"
  ],
  "host_permissions": [
    "*://*.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "externally_connectable": {
    "matches": [
      "*://localhost/*"
    ]
  }
}